# Supabase — copy this file to `.env` and fill in your project's values.
# Dashboard → Project Settings → API
#
# Both values are safe to expose in a client bundle: the anon key only grants
# what row-level security allows. NEVER put the `service_role` key here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
